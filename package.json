{
  "name": "yapatme",
  "desktopName": "yapatme",
  "version": "0.1.0",
  "description": "YapAtMe desktop note processing workspace",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "author": {
    "name": "Katarzyna Duda",
    "email": "katarzyna.duda@canonical.com"
  },
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "build:desktop": "vite build && electron-builder --linux AppImage deb",
    "preview": "vite preview",
    "app": "vite build && node tools/yapatme.cjs",
    "app:launch": "node tools/yapatme.cjs",
    "app:install": "node tools/install-launcher.cjs",
    "pkg:deb": "node tools/build-deb.cjs",
    "pkg:mac": "node tools/build-mac.cjs"
  },
  "build": {
    "appId": "com.yapatme.app",
    "productName": "YapAtMe",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "maintainer": "Katarzyna Duda <katarzyna.duda@canonical.com>",
      "syncDesktopName": true,
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "@milkdown/core": "^7.5.0",
    "@milkdown/kit": "^7.5.0",
    "@milkdown/plugin-history": "^7.5.0",
    "@milkdown/plugin-listener": "^7.5.0",
    "@milkdown/preset-gfm": "^7.5.0",
    "@milkdown/preset-commonmark": "^7.5.0",
    "@milkdown/react": "^7.5.0",
    "@milkdown/theme-nord": "^7.5.0",
    "idb-keyval": "^6.2.1",
    "lucide-react": "^0.469.0",
    "marked": "^15.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^37.1.0",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.7",
    "wait-on": "^8.0.3"
  }
}
