{
  "name": "prosemirror-drop-indicator",
  "type": "module",
  "version": "0.1.4",
  "description": "A ProseMirror plugin for drop indicator",
  "author": "ocavue <ocavue@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/prosekit/prosemirror-drop-indicator#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/prosekit/prosemirror-drop-indicator.git"
  },
  "bugs": "https://github.com/prosekit/prosemirror-drop-indicator/issues",
  "keywords": [],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@ocavue/utils": "^1.6.0",
    "prosemirror-model": "^1.25.7",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8"
  },
  "devDependencies": {
    "@ocavue/eslint-config": "^4.5.10",
    "@ocavue/tsconfig": "^0.7.1",
    "@types/node": "^22.0.0",
    "@vitest/browser-playwright": "^4.1.8",
    "eslint": "^10.4.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "fix": "eslint --fix . && prettier --write .",
    "test": "vitest",
    "test:install": "playwright install chromium",
    "typecheck": "tsc -b"
  }
}